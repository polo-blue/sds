{
  "name": "spoko-design-system",
  "version": "1.39.2",
  "type": "module",
  "private": false,
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./index.ts"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/*": "./src/styles/*",
    "./scripts/*": "./src/scripts/*",
    "./icons": "./icon.config.ts",
    "./icon-collections": "./icon.collections.ts",
    "./uno-config": "./uno-config/index.ts",
    "./components/*": "./src/components/*",
    "./components/Product/product-gallery.css": "./src/components/Product/product-gallery.css",
    "./scripts/product-gallery": "./src/components/Product/product-gallery.ts",
    "./astro/*": "./src/astro/*",
    "./vue/*": "./src/vue/*",
    "./react/*": "./src/react/*",
    "./utils/*": "./src/utils/*"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "pnpm build:tokens && astro build",
    "build:tokens": "node --experimental-strip-types scripts/build-tokens.ts",
    "build:css": "node --experimental-strip-types scripts/build-css.ts",
    "preview": "astro preview",
    "semantic-release": "semantic-release",
    "prepublishOnly": "pnpm run build",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,vue,astro,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,vue,astro,json,css,md}\"",
    "lint": "eslint \"src/**/*.{js,ts,jsx,tsx,vue,astro}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,jsx,tsx,vue,astro}\" --fix",
    "check": "astro check",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polo-blue/sds"
  },
  "author": {
    "name": "spokospace",
    "email": "szymon@spoko.space",
    "url": "https://spoko.space"
  },
  "homepage": "https://sds.spoko.space/",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "astro-starter",
    "seo",
    "astro",
    "sds design system",
    "spoko design system"
  ],
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/node": "^10.1.4",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.9",
    "@astrojs/vue": "^6.0.1",
    "@docsearch/css": "^4.6.3",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/vue": "^2.0.0",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/bx": "^1.2.3",
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/ei": "^1.2.2",
    "@iconify-json/el": "^1.2.2",
    "@iconify-json/eos-icons": "^1.2.4",
    "@iconify-json/et": "^1.2.1",
    "@iconify-json/flowbite": "^1.2.7",
    "@iconify-json/fluent": "^1.2.50",
    "@iconify-json/fluent-emoji": "1.2.7",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@iconify-json/la": "^1.2.1",
    "@iconify-json/lucide": "^1.2.112",
    "@iconify-json/material-symbols-light": "^1.2.78",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/noto-v1": "^1.2.5",
    "@iconify-json/octicon": "^1.2.28",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.86",
    "@iconify-json/streamline": "^1.2.5",
    "@iconify-json/streamline-emojis": "^1.2.4",
    "@iconify-json/streamline-freehand-color": "^1.2.2",
    "@iconify-json/system-uicons": "^1.2.4",
    "@iconify-json/uil": "^1.2.3",
    "@iconify-json/vscode-icons": "^1.2.57",
    "@iconify/json": "^2.2.486",
    "@iconify/vue": "^5.0.1",
    "@unocss/astro": "66.7.2",
    "@unocss/preset-attributify": "66.7.2",
    "@unocss/preset-typography": "66.7.2",
    "@unocss/preset-uno": "66.7.2",
    "@unocss/preset-web-fonts": "66.7.2",
    "@unocss/preset-wind": "66.7.2",
    "@unocss/reset": "66.7.2",
    "@vite-pwa/astro": "^1.2.0",
    "@vueuse/core": "^14.3.0",
    "astro-icon": "^1.1.5",
    "astro-meta-tags": "^0.4.1",
    "astro-navbar": "^2.4.0",
    "astro-pagefind": "^2.0.0",
    "astro-remote": "^0.3.4",
    "culori": "^4.0.2",
    "dotenv": "^17.4.2",
    "swiper": "^12.2.0",
    "unocss": "66.7.2",
    "vite-plugin-pwa": "^1.3.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/culori": "^4.0.1",
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@unocss/transformer-variant-group": "66.7.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/eslint-config-typescript": "^14.8.0",
    "astro": "^6.4.6",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.9",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "semantic-release": "^25.0.5",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "default": "9.15.3",
    "overrides": {
      "file-type@>=17.0.0 <17.1.3": ">=17.1.3",
      "sharp@<0.30.5": ">=0.30.5"
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp",
      "vue-demi"
    ]
  },
  "engines": {
    "node": ">=22.17.0",
    "pnpm": ">=10.16.1"
  }
}
