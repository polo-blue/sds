---
import MainLayout from '../../layouts/MainLayout.astro';
import PaletteConfigurator from '../../components/PaletteConfigurator.vue';
---

<MainLayout>
  <div class="max-w-4xl mx-auto px-4 py-8 sm:px-6">
    <h1 class="text-4xl font-bold mb-2">Palette Configurator</h1>
    <p class="text-gray-600 mb-8">
      Pick your brand colors and preview the generated OKLCH palette. Copy the config to use in your project.
    </p>
    <PaletteConfigurator client:load />
  </div>
</MainLayout>
