---
export interface SegmentedItem {
  value: string;
  label: string;
  href?: string;
  hreflang?: string;
  disabled?: boolean;
}

interface Props {
  variant?: 'switch' | 'segmented';
  size?: 'sm' | 'md' | 'lg';
  /** Visual style — 'default' uses SDS tokens; 'pill' / 'spoko' / 'outline' apply opinionated recipes */
  look?: 'default' | 'pill' | 'spoko' | 'outline';
  /** switch variant */
  checked?: boolean;
  label?: string;
  labelPosition?: 'before' | 'after';
  disabled?: boolean;
  name?: string;
  value?: string;
  /** segmented variant */
  items?: SegmentedItem[];
  current?: string;
  groupLabel?: string;
  reload?: boolean;
  class?: string;
}

const {
  variant = 'switch',
  size = 'md',
  look = 'default',
  checked = false,
  label,
  labelPosition = 'after',
  disabled = false,
  name,
  value,
  items = [],
  current,
  groupLabel = 'Options',
  reload = false,
  class: className = '',
} = Astro.props;

const sizeMap = {
  sm: {
    track: 'w-8 h-4',
    thumb: 'w-3 h-3',
    thumbTranslate: 'translate-x-4',
    label: 'text-xs',
    segBtn: 'px-2 py-1 text-xs',
  },
  md: {
    track: 'w-10 h-5',
    thumb: 'w-4 h-4',
    thumbTranslate: 'translate-x-5',
    label: 'text-sm',
    segBtn: 'px-3 py-1.5 text-sm',
  },
  lg: {
    track: 'w-12 h-6',
    thumb: 'w-5 h-5',
    thumbTranslate: 'translate-x-6',
    label: 'text-base',
    segBtn: 'px-4 py-2 text-base',
  },
};

const s = sizeMap[size];
---

{
  variant === 'switch' && (
    <button
      type="button"
      role="switch"
      aria-checked={checked ? 'true' : 'false'}
      aria-label={!label ? groupLabel : undefined}
      disabled={disabled}
      data-name={name}
      data-value={value}
      data-look={look}
      class:list={[
        'sds-toggle-switch inline-flex items-center gap-2 group',
        look === 'default' && 'inline-flex items-center gap-2',
        disabled && 'opacity-50 cursor-not-allowed',
        !disabled && 'cursor-pointer',
        className,
      ]}
    >
      {label && labelPosition === 'before' && (
        <span
          class:list={[
            'sds-toggle-label',
            look === 'default' && ['text-slate-dark dark:text-neutral-lighter', s.label],
          ]}
        >
          {label}
        </span>
      )}

      <span
        class:list={[
          'sds-toggle-track relative inline-flex shrink-0 rounded-full transition-colors',
          look === 'default' && [
            s.track,
            checked ? 'bg-blue-medium dark:bg-blue-light' : 'bg-slate-light dark:bg-slate-dark',
          ],
        ]}
        aria-hidden="true"
      >
        <span
          class:list={[
            'sds-toggle-thumb absolute top-1/2 left-0.5 -translate-y-1/2 bg-white rounded-full shadow transition-transform',
            look === 'default' && [s.thumb, checked && s.thumbTranslate],
          ]}
        />
      </span>

      {label && labelPosition === 'after' && (
        <span
          class:list={[
            'sds-toggle-label',
            look === 'default' && ['text-slate-dark dark:text-neutral-lighter', s.label],
          ]}
        >
          {label}
        </span>
      )}
    </button>
  )
}

{
  variant === 'segmented' && (
    <div
      role="group"
      aria-label={groupLabel}
      data-look={look}
      class:list={[
        'sds-toggle-segmented',
        look === 'default' &&
          'inline-flex items-center gap-0.5 p-0.5 rounded-lg bg-slate-100 dark:bg-slate-dark border border-slate-200 dark:border-slate-darkest',
        className,
      ]}
    >
      {items.map(item => {
        const isActive = item.value === current;
        const isLink = !!item.href;
        const isDisabled = !!item.disabled;
        const baseClasses = [
          'sds-toggle-seg-btn',
          look === 'default' && [
            'inline-flex items-center justify-center gap-1.5 rounded-md font-textbold transition-colors',
            s.segBtn,
            isActive
              ? 'bg-white dark:bg-slate-darkest text-blue-medium dark:text-blue-light shadow-sm'
              : 'text-slate-dark dark:text-neutral-lighter hover:bg-white/60 dark:hover:bg-slate-darkest/60',
          ],
          isActive && 'is-active',
          isDisabled && 'opacity-50 cursor-not-allowed pointer-events-none',
        ];

        if (isLink) {
          return (
            <a
              href={item.href}
              class:list={baseClasses}
              aria-current={isActive ? 'page' : undefined}
              aria-disabled={isDisabled ? 'true' : undefined}
              hreflang={item.hreflang}
              data-value={item.value}
              data-reload={reload ? 'true' : undefined}
            >
              {item.label}
            </a>
          );
        }

        return (
          <button
            type="button"
            role="radio"
            aria-checked={isActive ? 'true' : 'false'}
            disabled={isDisabled}
            tabindex={isActive ? 0 : -1}
            data-value={item.value}
            class:list={baseClasses}
          >
            {item.label}
          </button>
        );
      })}
    </div>
  )
}

<style is:global>
  .sds-toggle-switch:focus-visible .sds-toggle-track,
  .sds-toggle-seg-btn:focus-visible {
    outline: 2px solid theme('colors.blue.medium');
    outline-offset: 2px;
  }

  html.dark .sds-toggle-switch:focus-visible .sds-toggle-track,
  html.dark .sds-toggle-seg-btn:focus-visible {
    outline-color: theme('colors.blue.light');
  }

  /* ── look="pill" — catalog.polo.blue lang-toggle ─────────────────── */
  .sds-toggle-segmented[data-look='pill'] {
    display: inline-flex;
    padding: 3px;
    background: #fff;
    border: 1px solid rgba(0, 15, 40, 0.14);
    border-radius: 999px;
  }
  .sds-toggle-segmented[data-look='pill'] .sds-toggle-seg-btn {
    min-width: 38px;
    height: 30px;
    padding: 0 12px;
    border: none;
    background: transparent;
    color: theme('colors.blue.darkest');
    font: inherit;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-indent: 0.06em;
    line-height: 1;
    text-transform: uppercase;
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.16s ease,
      color 0.16s ease;
  }
  .sds-toggle-segmented[data-look='pill'] .sds-toggle-seg-btn:hover:not(.is-active) {
    background: rgba(0, 15, 40, 0.04);
  }
  .sds-toggle-segmented[data-look='pill'] .sds-toggle-seg-btn.is-active {
    background: theme('colors.blue.darkest');
    color: #fff;
  }
  html.dark .sds-toggle-segmented[data-look='pill'] {
    background: theme('colors.slate.darkest');
    border-color: rgba(255, 255, 255, 0.14);
  }
  html.dark .sds-toggle-segmented[data-look='pill'] .sds-toggle-seg-btn {
    color: theme('colors.neutral.lighter');
  }
  html.dark .sds-toggle-segmented[data-look='pill'] .sds-toggle-seg-btn.is-active {
    background: #fff;
    color: theme('colors.blue.darkest');
  }

  /* ── look="spoko" — spoko.space lang-segmented ───────────────────── */
  .sds-toggle-segmented[data-look='spoko'] {
    display: inline-flex;
    padding: 2px;
    background: transparent;
    border: 1px solid rgba(10, 22, 40, 0.12);
    border-radius: 999px;
    gap: 0;
  }
  .sds-toggle-segmented[data-look='spoko'] .sds-toggle-seg-btn {
    background: transparent;
    color: inherit;
    border: none;
    cursor: pointer;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    font-family: inherit;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }
  .sds-toggle-segmented[data-look='spoko'] .sds-toggle-seg-btn:hover:not(.is-active) {
    color: theme('colors.blue.medium');
  }
  .sds-toggle-segmented[data-look='spoko'] .sds-toggle-seg-btn.is-active {
    background: #0a1628;
    color: #fff;
  }
  html.dark .sds-toggle-segmented[data-look='spoko'] {
    border-color: rgba(255, 255, 255, 0.15);
  }
  html.dark .sds-toggle-segmented[data-look='spoko'] .sds-toggle-seg-btn.is-active {
    background: rgba(255, 255, 255, 0.92);
    color: #0a1628;
  }

  /* ── look="outline" — catalog.polo.blue toggler (switch with frame) ── */
  .sds-toggle-switch[data-look='outline'] {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px 4px 6px;
    background: #fff;
    border: 1px solid rgba(15, 17, 22, 0.09);
    border-radius: 999px;
    color: theme('colors.slate.dark');
    transition:
      border-color 0.14s,
      background 0.14s,
      color 0.14s;
  }
  .sds-toggle-switch[data-look='outline']:hover {
    border-color: color-mix(in oklab, theme('colors.blue.darker') 35%, rgba(15, 17, 22, 0.09));
  }
  .sds-toggle-switch[data-look='outline'] .sds-toggle-track {
    position: relative;
    width: 30px;
    height: 17px;
    flex-shrink: 0;
    border-radius: 999px;
    background: color-mix(in oklab, theme('colors.slate.light') 40%, rgba(15, 17, 22, 0.09));
    transition: background 0.14s;
  }
  .sds-toggle-switch[data-look='outline'] .sds-toggle-thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    right: auto;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 2px rgba(15, 17, 22, 0.3);
    transition:
      left 0.14s,
      right 0.14s;
    transform: none;
  }
  .sds-toggle-switch[data-look='outline'][aria-checked='true'] {
    color: theme('colors.blue.darker');
    border-color: color-mix(in oklab, theme('colors.blue.darker') 30%, rgba(15, 17, 22, 0.09));
  }
  .sds-toggle-switch[data-look='outline'][aria-checked='true'] .sds-toggle-track {
    background: theme('colors.blue.darker');
  }
  .sds-toggle-switch[data-look='outline'][aria-checked='true'] .sds-toggle-thumb {
    left: auto;
    right: 2px;
  }
  .sds-toggle-switch[data-look='outline'] .sds-toggle-label {
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }
  html.dark .sds-toggle-switch[data-look='outline'] {
    background: theme('colors.slate.darkest');
    border-color: rgba(255, 255, 255, 0.12);
    color: theme('colors.neutral.lighter');
  }
  html.dark .sds-toggle-switch[data-look='outline'][aria-checked='true'] {
    color: theme('colors.blue.light');
  }
  html.dark .sds-toggle-switch[data-look='outline'][aria-checked='true'] .sds-toggle-track {
    background: theme('colors.blue.light');
  }
</style>

<script>
  function setupSwitches() {
    document.querySelectorAll<HTMLButtonElement>('.sds-toggle-switch').forEach(btn => {
      if (btn.dataset.sdsToggleBound === '1') return;
      btn.dataset.sdsToggleBound = '1';

      btn.addEventListener('click', () => {
        if (btn.disabled) return;
        const next = btn.getAttribute('aria-checked') !== 'true';
        btn.setAttribute('aria-checked', next ? 'true' : 'false');

        const look = btn.dataset.look || 'default';
        if (look === 'default') {
          const thumb = btn.querySelector<HTMLElement>('.sds-toggle-thumb');
          const track = btn.querySelector<HTMLElement>('.sds-toggle-track');
          if (track) {
            track.classList.toggle('bg-blue-medium', next);
            track.classList.toggle('dark:bg-blue-light', next);
            track.classList.toggle('bg-slate-light', !next);
            track.classList.toggle('dark:bg-slate-dark', !next);
          }
          if (thumb) {
            if (next) {
              if (track?.classList.contains('w-8')) thumb.classList.add('translate-x-4');
              else if (track?.classList.contains('w-12')) thumb.classList.add('translate-x-6');
              else thumb.classList.add('translate-x-5');
            } else {
              thumb.classList.remove('translate-x-4', 'translate-x-5', 'translate-x-6');
            }
          }
        }

        btn.dispatchEvent(
          new CustomEvent('toggle-change', {
            bubbles: true,
            detail: { name: btn.dataset.name, value: btn.dataset.value, checked: next },
          })
        );
      });
    });
  }

  function setupSegmented() {
    document.querySelectorAll<HTMLElement>('.sds-toggle-segmented').forEach(group => {
      if (group.dataset.sdsToggleBound === '1') return;
      group.dataset.sdsToggleBound = '1';

      const radios = Array.from(group.querySelectorAll<HTMLElement>('[role="radio"]:not([disabled])'));

      const look = group.dataset.look || 'default';

      radios.forEach(radio => {
        radio.addEventListener('click', () => {
          radios.forEach(r => {
            r.setAttribute('aria-checked', 'false');
            r.setAttribute('tabindex', '-1');
            r.classList.remove('is-active');
            if (look === 'default') {
              r.classList.remove(
                'bg-white',
                'dark:bg-slate-darkest',
                'text-blue-medium',
                'dark:text-blue-light',
                'shadow-sm'
              );
              r.classList.add('text-slate-dark', 'dark:text-neutral-lighter');
            }
          });
          radio.setAttribute('aria-checked', 'true');
          radio.setAttribute('tabindex', '0');
          radio.classList.add('is-active');
          if (look === 'default') {
            radio.classList.add(
              'bg-white',
              'dark:bg-slate-darkest',
              'text-blue-medium',
              'dark:text-blue-light',
              'shadow-sm'
            );
            radio.classList.remove('text-slate-dark', 'dark:text-neutral-lighter');
          }
          group.dispatchEvent(
            new CustomEvent('toggle-change', {
              bubbles: true,
              detail: { value: radio.dataset.value },
            })
          );
        });

        radio.addEventListener('keydown', e => {
          if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
          e.preventDefault();
          const idx = radios.indexOf(radio);
          const next =
            e.key === 'ArrowRight'
              ? radios[(idx + 1) % radios.length]
              : radios[(idx - 1 + radios.length) % radios.length];
          (next as HTMLElement).focus();
          (next as HTMLElement).click();
        });
      });

      group.querySelectorAll<HTMLAnchorElement>('a[data-reload="true"]').forEach(link => {
        if (link.dataset.sdsToggleBound === '1') return;
        link.dataset.sdsToggleBound = '1';
        link.addEventListener('click', e => {
          e.preventDefault();
          window.location.href = link.href;
        });
      });
    });
  }

  function setup() {
    setupSwitches();
    setupSegmented();
  }

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
