---
import { SITE } from '../../config';
import SkipToContent from './SkipToContent.astro';
import Search from 'astro-pagefind/components/Search';
---

<header
  class="p-3 bg-blue-medium bg-opacity-10 dark:bg-slate-darkest dark:border-slate-dark backdrop-blur-md border-b text-slate-900 dark:text-neutral-lighter"
>
  <SkipToContent />
  <nav title="Top Navigation" class="mx-auto flex justify-between items-center px-4">
    <div class="flex items-center gap-2">
      <button
        type="button"
        id="nav-drawer-trigger"
        class="lg:hidden p-2 -ml-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-dark transition-colors text-slate-700 dark:text-neutral-light"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span class="sds-hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

      <a
        class="text-2xl font-medium block font-textbold leading-none my-auto text-blue-medium dark:text-blue-light"
        href="/"
      >
        SDS
      </a>

      <Search
        transition:persist
        transition:name="search-field"
        className="search-container"
        id="search"
        uiOptions={{
          showImages: false,
          showFilters: false,
          resetStyles: true,
        }}
      />
    </div>

    <div class="flex gap-2 items-center">
      <button
        type="button"
        id="dark-mode-toggle"
        class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-dark transition-colors text-slate-700 dark:text-neutral-light"
        aria-label="Toggle dark mode"
      >
        <span class="i-lucide-moon text-xl dark:hidden" aria-hidden="true"></span>
        <span class="i-lucide-sun text-xl hidden dark:inline-block" aria-hidden="true"></span>
      </button>
      {
        SITE.github && (
          <a
            title="Github"
            class="opacity-80 hover:opacity-100 hover:bg-slate-200 dark:hover:bg-slate-dark p-2 rounded-full transition-colors"
            href={'https://github.com/' + SITE.github}
          >
            <img class="h-7" src="/github.svg" alt="github logo" />
          </a>
        )
      }
      {
        SITE.linkedin && (
          <a
            title="linkedin"
            class="opacity-80 hover:opacity-100 hover:bg-blue-50 p-2 rounded-full transition-colors"
            href={'https://linkedin.com/in/' + SITE.linkedin}
          >
            <img class="h-7" src="/linkedin.svg" alt="linkedin logo" />
          </a>
        )
      }
    </div>
  </nav>
</header>

<style is:global>
  #search {
    @apply ml-6;
  }

  .search-container {
    box-sizing: border-box;
    @apply h-10 border-0 border-gray-800 rounded-3xl hidden md:block;
  }

  .pagefind-ui {
    @apply font-textlight text-base;
  }

  .pagefind-ui .pagefind-ui__search-input {
    height: 40px;
    border: 0;
    @apply rounded-none sm:rounded-3xl w-full;
  }

  .pagefind-ui .pagefind-ui__result-excerpt,
  .pagefind-ui .pagefind-ui__button {
    font-size: 14px;
  }

  .pagefind-ui .pagefind-ui__filter-name {
    font-size: 12px;
  }

  .pagefind-ui .pagefind-ui__drawer:not(.pagefind-ui__hidden) {
    @apply p-4;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: var(--pagefind-ui-primary);
    font-family: vw_headlight;
    font-size: 1rem;
  }

  .pagefind-ui .pagefind-ui__result-link::before {
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    content: '';
    position: absolute;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: var(--pagefind-ui-text);
    order: 3;
  }

  .pagefind-ui .pagefind-ui__drawer {
    @apply bg-white md:fixed shadow-lg rounded-b-lg border-t border-t-transparent overflow-auto top-17 md:max-w-[calc(100vw-10%)] max-h-[calc(100vh-10%)] gap-[30px];
  }

  /* Dark mode: override Pagefind CSS variables and explicit white backgrounds */
  html.dark .pagefind-ui {
    --pagefind-ui-background: theme('colors.slate.darkest');
    --pagefind-ui-text: theme('colors.neutral.lighter');
    --pagefind-ui-border: theme('colors.slate.dark');
    --pagefind-ui-tag: theme('colors.slate.dark');
  }

  html.dark .pagefind-ui .pagefind-ui__search-input {
    @apply bg-slate-dark text-neutral-lighter placeholder:text-neutral-light;
  }

  html.dark .pagefind-ui .pagefind-ui__drawer {
    @apply bg-slate-darkest text-neutral-lighter;
  }

  .pagefind-ui .pagefind-ui__search-clear {
    height: 38px;
    top: 0;
    @apply sm:rounded-3xl;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-size: 1rem;
    font-weight: 400;
    padding: 0 2.5rem 2px;
  }

  .pagefind-ui .pagefind-ui__form::before {
    top: 14px;
    left: 16px;
    width: 14px;
    height: 14px;
  }

  .pagefind-ui .pagefind-ui__result {
    padding: 0.875rem 0;
    gap: 1rem;
    @apply relative;
  }

  .pagefind-ui .pagefind-ui__filter-block {
    padding: 0.875rem 0;
    border-width: 1px;
  }

  .pagefind-ui .pagefind-ui__filter-group {
    gap: 0.5rem;
    padding-top: 0.875rem;
  }

  .pagefind-ui .pagefind-ui__filter-value {
    gap: 10px;
  }

  .pagefind-ui .pagefind-ui__filter-checkbox {
    border-radius: 3px;
    margin-top: 1px;
    min-width: calc(16px * var(--pagefind-ui-scale));
  }

  .pagefind-ui .pagefind-ui__result-image {
    @apply drop-shadow-sm w-full h-full object-contain rounded-none;
  }

  .pagefind-ui .pagefind-ui__filter-panel {
    @apply hidden;
  }

  .pagefind-ui .pagefind-ui__filter-label {
    font-size: 0.9rem;
  }

  .pagefind-ui .pagefind-ui__button {
    font-weight: 400;
    height: 40px;
  }

  .pagefind-ui .pagefind-ui__result-tag {
    background: inherit;
    padding: 0;
    color: #9ca3af;
  }

  .pagefind-ui .pagefind-ui__result-thumb {
    max-width: 120px;
  }

  .pagefind-ui .pagefind-ui__result-tags {
    margin-top: 0.4rem;
    order: 2;
  }

  .pagefind-ui .pagefind-ui__filter-name::after {
    color: var(--pagefind-ui-primary);
  }

  .pagefind-ui .pagefind-ui__result-title {
    font-size: inherit;
    line-height: 1;
  }

  .pagefind-ui .pagefind-ui__filter-panel,
  .pagefind-ui .pagefind-ui__results-area {
    margin-top: 0;
  }

  .pagefind-ui .pagefind-ui__message {
    padding: 0.875rem 0;
  }

  /* Hamburger icon */
  .sds-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 20px;
    pointer-events: none;
  }

  .sds-hamburger > span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition:
      transform 0.25s ease,
      opacity 0.2s ease;
  }

  body.drawer-open .sds-hamburger > span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  body.drawer-open .sds-hamburger > span:nth-child(2) {
    opacity: 0;
  }

  body.drawer-open .sds-hamburger > span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  function setupDarkModeToggle() {
    const toggle = document.getElementById('dark-mode-toggle');
    if (toggle) {
      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('sds-color-scheme', isDark ? 'dark' : 'light');
      });
    }
  }

  document.addEventListener('astro:page-load', setupDarkModeToggle);
  document.addEventListener('astro:after-swap', setupDarkModeToggle);
  setupDarkModeToggle();
</script>
