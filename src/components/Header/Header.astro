---
import { SITE } from '../../config';
import SkipToContent from './SkipToContent.astro';
import SearchModal from './SearchModal.vue';
---

<header
  class="p-3 bg-blue-medium bg-opacity-10 dark:bg-slate-darkest dark:border-slate-dark backdrop-blur-md border-b text-slate-900 dark:text-neutral-lighter"
>
  <SkipToContent />
  <nav title="Top Navigation" class="mx-auto flex justify-between items-center px-4">
    <div class="flex items-center gap-2">
      <button
        type="button"
        id="nav-drawer-trigger"
        class="lg:hidden p-2 -ml-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-dark transition-colors text-slate-700 dark:text-neutral-light"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span class="sds-hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

      <a
        class="text-2xl font-medium block font-textbold leading-none my-auto text-blue-medium dark:text-blue-light"
        href="/"
      >
        SDS
      </a>

      <button
        type="button"
        class="sds-search-trigger ml-6 hidden md:flex items-center gap-2 px-3 h-9 rounded-lg border border-slate-200 dark:border-slate-dark bg-slate-50 dark:bg-slate-darkest text-slate-500 dark:text-neutral-light hover:border-blue-medium dark:hover:border-blue-light hover:text-slate-900 dark:hover:text-neutral-lighter transition-colors min-w-56 text-left"
        aria-label="Open search"
        onclick="window.dispatchEvent(new CustomEvent('sds-open-search'))"
      >
        <span class="i-lucide-search text-base" aria-hidden="true"></span>
        <span class="text-sm flex-1">Search docs…</span>
        <span class="hidden lg:inline-flex items-center gap-1 text-xs">
          <kbd
            class="px-1.5 py-0.5 border border-slate-300 dark:border-slate-dark rounded-sm bg-white dark:bg-slate-dark font-mono text-[0.65rem] leading-none"
            >Ctrl</kbd
          >
          <kbd
            class="px-1.5 py-0.5 border border-slate-300 dark:border-slate-dark rounded-sm bg-white dark:bg-slate-dark font-mono text-[0.65rem] leading-none"
            >K</kbd
          >
        </span>
      </button>
      <button
        type="button"
        class="sds-search-trigger md:hidden p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-dark transition-colors text-slate-700 dark:text-neutral-light"
        aria-label="Open search"
        onclick="window.dispatchEvent(new CustomEvent('sds-open-search'))"
      >
        <span class="i-lucide-search text-xl" aria-hidden="true"></span>
      </button>
    </div>

    <div class="flex gap-2 items-center">
      <button
        type="button"
        id="dark-mode-toggle"
        class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-dark transition-colors text-slate-700 dark:text-neutral-light"
        aria-label="Toggle dark mode"
      >
        <span class="i-lucide-moon text-xl dark:hidden" aria-hidden="true"></span>
        <span class="i-lucide-sun text-xl hidden dark:inline-block" aria-hidden="true"></span>
      </button>
      {
        SITE.github && (
          <a
            title="Github"
            class="opacity-80 hover:opacity-100 hover:bg-slate-200 dark:hover:bg-slate-dark p-2 rounded-full transition-colors"
            href={'https://github.com/' + SITE.github}
          >
            <img class="h-7" src="/github.svg" alt="github logo" />
          </a>
        )
      }
      {
        SITE.linkedin && (
          <a
            title="linkedin"
            class="opacity-80 hover:opacity-100 hover:bg-blue-50 p-2 rounded-full transition-colors"
            href={'https://linkedin.com/in/' + SITE.linkedin}
          >
            <img class="h-7" src="/linkedin.svg" alt="linkedin logo" />
          </a>
        )
      }
    </div>
  </nav>
</header>

<SearchModal client:load />

<style is:global>
  /* Hamburger icon — also used by Navbar */
  .sds-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 20px;
    pointer-events: none;
  }

  .sds-hamburger > span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition:
      transform 0.25s ease,
      opacity 0.2s ease;
  }

  body.drawer-open .sds-hamburger > span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  body.drawer-open .sds-hamburger > span:nth-child(2) {
    opacity: 0;
  }

  body.drawer-open .sds-hamburger > span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  function setupDarkModeToggle() {
    const toggle = document.getElementById('dark-mode-toggle');
    if (toggle && toggle.dataset.bound !== '1') {
      toggle.dataset.bound = '1';
      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
        try {
          localStorage.setItem('sds-color-scheme', isDark ? 'dark' : 'light');
        } catch {
          /* localStorage may be unavailable */
        }
      });
    }
  }

  document.addEventListener('astro:page-load', setupDarkModeToggle);
  document.addEventListener('astro:after-swap', setupDarkModeToggle);
  setupDarkModeToggle();
</script>
