---
import Drawer from './Drawer.astro';

export interface MenuPrimaryItem {
  title: string;
  sub?: string;
  href: string;
}

export interface MenuChip {
  label: string;
  href: string;
}

export interface MenuChipsSection {
  title: string;
  items: MenuChip[];
}

export interface MenuHelpCard {
  title: string;
  sub?: string;
  cta: { label: string; href: string };
}

export interface MenuLocale {
  code: string;
  label: string;
  href: string;
  active?: boolean;
}

export interface MenuSocial {
  label: string;
  href: string;
  /** SVG path data, e.g. 'M24 12.073c0-6.627...' — keeps the component icon-library-agnostic */
  iconPath?: string;
  /** Optional inline SVG (full markup) — overrides iconPath if provided */
  iconSvg?: string;
}

interface Props {
  id: string;
  label?: string;
  position?: 'left' | 'right';
  brand?: {
    href?: string;
    logoSrc?: string;
    logoAlt?: string;
    text?: string;
  };
  primary?: MenuPrimaryItem[];
  chips?: MenuChipsSection;
  helpCard?: MenuHelpCard;
  footer?: {
    locales?: MenuLocale[];
    themeToggle?: boolean;
    socials?: MenuSocial[];
  };
}

const { id, label = 'Menu', position = 'left', brand, primary = [], chips, helpCard, footer } = Astro.props;

const headingId = `${id}-heading`;
---

<Drawer id={id} label={label} position={position} class="sds-drawer-menu">
  <div class="sds-menu">
    {
      (brand || Astro.slots.has('close')) && (
        <header class="sds-menu-header">
          {Astro.slots.has('brand') ? (
            <slot name="brand" />
          ) : brand ? (
            <a
              href={brand.href ?? '/'}
              class="sds-menu-brand"
              aria-label={brand.logoAlt ?? brand.text ?? 'Home'}
            >
              {brand.logoSrc ? (
                <img src={brand.logoSrc} alt={brand.logoAlt ?? ''} loading="eager" />
              ) : (
                <span class="sds-menu-brand-text">{brand.text}</span>
              )}
            </a>
          ) : (
            <span />
          )}

          <button type="button" class="sds-menu-close" aria-label="Close menu" data-drawer-close>
            <span class="sds-menu-close-icon" aria-hidden="true">
              <span />
              <span />
            </span>
          </button>
        </header>
      )
    }

    <h2 id={headingId} class="sr-only">{label}</h2>

    {
      (primary.length > 0 || Astro.slots.has('primary')) && (
        <nav class="sds-menu-primary" aria-label={label}>
          {Astro.slots.has('primary') ? (
            <slot name="primary" />
          ) : (
            primary.map(item => (
              <a href={item.href} class="sds-menu-primary-link" data-drawer-close>
                <div class="sds-menu-primary-text">
                  <span class="sds-menu-primary-title">{item.title}</span>
                  {item.sub && <span class="sds-menu-primary-sub">{item.sub}</span>}
                </div>
                <svg
                  class="sds-menu-primary-arrow"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))
          )}
        </nav>
      )
    }

    {
      (chips || Astro.slots.has('chips')) && (
        <section class="sds-menu-section" aria-label={chips?.title}>
          {Astro.slots.has('chips') ? (
            <slot name="chips" />
          ) : chips ? (
            <>
              <h3 class="sds-menu-section-title">{chips.title}</h3>
              <div class="sds-menu-chips">
                {chips.items.map(chip => (
                  <a href={chip.href} class="sds-menu-chip" data-drawer-close>
                    {chip.label}
                  </a>
                ))}
              </div>
            </>
          ) : null}
        </section>
      )
    }

    {Astro.slots.has('middle') && <slot name="middle" />}

    <div class="sds-menu-spacer"></div>

    {
      (helpCard || Astro.slots.has('help')) && (
        <section class="sds-menu-help-card" aria-label={helpCard?.title}>
          {Astro.slots.has('help') ? (
            <slot name="help" />
          ) : helpCard ? (
            <>
              <div class="sds-menu-help-text">
                <p class="sds-menu-help-title">{helpCard.title}</p>
                {helpCard.sub && <p class="sds-menu-help-sub">{helpCard.sub}</p>}
              </div>
              <a href={helpCard.cta.href} class="sds-menu-help-cta" data-drawer-close>
                {helpCard.cta.label}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </>
          ) : null}
        </section>
      )
    }

    {
      (footer || Astro.slots.has('footer-left') || Astro.slots.has('footer-right')) && (
        <footer class="sds-menu-footer">
          <div class="sds-menu-footer-utility">
            {Astro.slots.has('footer-left') ? (
              <slot name="footer-left" />
            ) : (
              <>
                {footer?.locales && footer.locales.length > 0 && (
                  <div class="sds-menu-lang" role="group" aria-label="Language">
                    {footer.locales.map(locale => (
                      <a
                        href={locale.href}
                        class:list={['sds-menu-lang-btn', locale.active && 'is-active']}
                        aria-current={locale.active ? 'page' : undefined}
                        hreflang={locale.code}
                      >
                        {locale.label}
                      </a>
                    ))}
                  </div>
                )}
                {footer?.themeToggle && (
                  <button
                    type="button"
                    class="sds-menu-theme-chip"
                    aria-label="Toggle dark mode"
                    data-sds-menu-theme-toggle
                  >
                    <svg
                      class="hidden dark:block"
                      width="16"
                      height="16"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
                    </svg>
                    <svg
                      class="block dark:hidden"
                      width="16"
                      height="16"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
                    </svg>
                  </button>
                )}
              </>
            )}
          </div>

          {Astro.slots.has('footer-right') ? (
            <slot name="footer-right" />
          ) : (
            footer?.socials &&
            footer.socials.length > 0 && (
              <div class="sds-menu-footer-socials">
                {footer.socials.map(social =>
                  social.iconSvg ? (
                    <a
                      href={social.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={social.label}
                      class="sds-menu-footer-social"
                      set:html={social.iconSvg}
                    />
                  ) : (
                    <a
                      href={social.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={social.label}
                      class="sds-menu-footer-social"
                    >
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        {social.iconPath && <path d={social.iconPath} />}
                      </svg>
                    </a>
                  )
                )}
              </div>
            )
          )}
        </footer>
      )
    }
  </div>
</Drawer>

<style is:global>
  /* Override drawer panel sizing + dark mode background for menu layout */
  .sds-drawer-menu .sds-drawer-panel {
    width: 380px;
    max-width: 100vw;
    padding: 24px 32px 28px;
    background: #ffffff;
  }
  html.dark .sds-drawer-menu .sds-drawer-panel {
    background: theme('colors.slate.darkest');
    border-left-color: rgba(255, 255, 255, 0.08);
  }
  html.dark .sds-drawer-menu[data-position='right'] .sds-drawer-panel {
    border-left: none;
    border-right-color: rgba(255, 255, 255, 0.08);
  }
  @media (max-width: 480px) {
    .sds-drawer-menu .sds-drawer-panel {
      padding: 20px 20px 24px;
    }
  }

  .sds-menu {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    color: theme('colors.slate.darkest');
  }
  html.dark .sds-menu {
    color: theme('colors.neutral.lighter');
  }

  /* ── Header ──────────────────────────────────────────────────────── */
  .sds-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .sds-menu-brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .sds-menu-brand-text {
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: theme('colors.blue.medium');
  }
  html.dark .sds-menu-brand-text {
    color: theme('colors.blue.light');
  }
  .sds-menu-brand img {
    display: block;
    height: 34px;
    width: auto;
    object-fit: contain;
  }
  .sds-menu-close {
    background: transparent;
    border: 1px solid rgba(10, 22, 40, 0.1);
    color: inherit;
    cursor: pointer;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s ease,
      transform 0.3s ease;
  }
  .sds-menu-close:hover {
    background: rgba(10, 22, 40, 0.05);
    transform: rotate(90deg);
  }
  html.dark .sds-menu-close {
    border-color: rgba(255, 255, 255, 0.1);
  }
  html.dark .sds-menu-close:hover {
    background: rgba(255, 255, 255, 0.06);
  }
  .sds-menu-close-icon {
    position: relative;
    display: block;
    width: 14px;
    height: 14px;
  }
  .sds-menu-close-icon > span {
    position: absolute;
    top: calc(50% - 1px);
    left: 0;
    display: block;
    width: 14px;
    height: 1.8px;
    background: currentColor;
    border-radius: 2px;
  }
  .sds-menu-close-icon > span:first-child {
    transform: rotate(45deg);
  }
  .sds-menu-close-icon > span:last-child {
    transform: rotate(-45deg);
  }

  /* ── Primary nav ─────────────────────────────────────────────────── */
  .sds-menu-primary {
    display: flex;
    flex-direction: column;
    margin-bottom: 32px;
  }
  .sds-menu-primary-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 4px;
    border-bottom: 1px solid rgba(10, 22, 40, 0.08);
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  html.dark .sds-menu-primary-link {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }
  .sds-menu-primary-link:hover {
    color: theme('colors.blue.medium');
  }
  html.dark .sds-menu-primary-link:hover {
    color: theme('colors.blue.light');
  }
  .sds-menu-primary-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sds-menu-primary-title {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  @media (max-width: 767px) {
    .sds-menu-primary-title {
      font-size: 1.25rem;
    }
  }
  .sds-menu-primary-sub {
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(15, 18, 25, 0.55);
    letter-spacing: 0;
  }
  html.dark .sds-menu-primary-sub {
    color: rgba(241, 245, 249, 0.5);
  }
  .sds-menu-primary-arrow {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    opacity: 0.55;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }
  .sds-menu-primary-link:hover .sds-menu-primary-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  /* ── Sections + chips ────────────────────────────────────────────── */
  .sds-menu-section {
    margin-bottom: 24px;
  }
  .sds-menu-section-title {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(15, 18, 25, 0.55);
    margin-bottom: 10px;
  }
  html.dark .sds-menu-section-title {
    color: rgba(241, 245, 249, 0.5);
  }
  .sds-menu-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .sds-menu-chip {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border: 1px solid rgba(10, 22, 40, 0.18);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: inherit;
    text-decoration: none;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .sds-menu-chip:hover {
    background: rgba(10, 22, 40, 0.05);
    border-color: rgba(10, 22, 40, 0.3);
  }
  html.dark .sds-menu-chip {
    border-color: rgba(255, 255, 255, 0.18);
  }
  html.dark .sds-menu-chip:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.3);
  }

  /* ── Spacer + help card ──────────────────────────────────────────── */
  .sds-menu-spacer {
    flex: 1;
    min-height: 16px;
  }
  .sds-menu-help-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    background: rgba(0, 30, 80, 0.06);
    border-radius: 14px;
    margin-bottom: 24px;
  }
  html.dark .sds-menu-help-card {
    background: rgba(255, 255, 255, 0.05);
  }
  .sds-menu-help-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .sds-menu-help-title {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }
  .sds-menu-help-sub {
    font-size: 0.75rem;
    color: rgba(15, 18, 25, 0.6);
    margin: 0;
  }
  html.dark .sds-menu-help-sub {
    color: rgba(241, 245, 249, 0.5);
  }
  .sds-menu-help-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: linear-gradient(135deg, theme('colors.blue.medium'), theme('colors.blue.darker'));
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }
  .sds-menu-help-cta:hover {
    opacity: 0.92;
  }
  .sds-menu-help-cta svg {
    transition: transform 0.2s ease;
  }
  .sds-menu-help-cta:hover svg {
    transform: translateX(3px);
  }

  /* ── Footer (lang + theme + socials) ─────────────────────────────── */
  .sds-menu-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid rgba(10, 22, 40, 0.1);
  }
  html.dark .sds-menu-footer {
    border-top-color: rgba(255, 255, 255, 0.1);
  }
  .sds-menu-footer-utility {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sds-menu-lang {
    display: inline-flex;
    border: 1px solid rgba(10, 22, 40, 0.15);
    border-radius: 999px;
    padding: 2px;
  }
  html.dark .sds-menu-lang {
    border-color: rgba(255, 255, 255, 0.18);
  }
  .sds-menu-lang-btn {
    background: transparent;
    color: inherit;
    border: none;
    cursor: pointer;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }
  .sds-menu-lang-btn:hover:not(.is-active) {
    color: theme('colors.blue.medium');
  }
  .sds-menu-lang-btn.is-active {
    background: theme('colors.blue.darkest');
    color: #fff;
  }
  html.dark .sds-menu-lang-btn.is-active {
    background: rgba(255, 255, 255, 0.92);
    color: theme('colors.blue.darkest');
  }

  .sds-menu-theme-chip {
    background: transparent;
    color: inherit;
    border: 1px solid rgba(10, 22, 40, 0.15);
    cursor: pointer;
    width: 32px;
    height: 32px;
    padding: 0;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .sds-menu-theme-chip:hover {
    border-color: theme('colors.blue.medium');
    color: theme('colors.blue.medium');
  }
  html.dark .sds-menu-theme-chip {
    border-color: rgba(255, 255, 255, 0.18);
  }
  html.dark .sds-menu-theme-chip:hover {
    border-color: theme('colors.blue.light');
    color: theme('colors.blue.light');
  }

  .sds-menu-footer-socials {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .sds-menu-footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    color: inherit;
    text-decoration: none;
    opacity: 0.7;
    transition:
      opacity 0.2s ease,
      background 0.2s ease;
  }
  .sds-menu-footer-social:hover {
    opacity: 1;
    background: rgba(10, 22, 40, 0.06);
  }
  html.dark .sds-menu-footer-social:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  /* sr-only utility */
  .sds-menu .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  function setupThemeToggles() {
    document.querySelectorAll<HTMLButtonElement>('[data-sds-menu-theme-toggle]').forEach(btn => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
        try {
          localStorage.setItem('sds-color-scheme', isDark ? 'dark' : 'light');
        } catch {
          /* localStorage may be unavailable */
        }
      });
    });
  }

  setupThemeToggles();
  document.addEventListener('astro:after-swap', setupThemeToggles);
</script>
